# RPC endpoint for Polkadot Hub testnet (EVM)
HUB_RPC_URL=

# Deployer private key (0x...)
HUB_PRIVATE_KEY=

# Asset Hub WS endpoint for XCM encoding
ASSET_HUB_WS_URL=

# Hub WS endpoint for XCM encoding (Substrate)
HUB_WS_URL=

# Beneficiary SS58 address on Asset Hub
BENEFICIARY_SS58=

# Optional: default XCM amount (Planck units)
XCM_AMOUNT=

# Substrate signer for XCM extrinsic (sr25519 mnemonic)
SUBSTRATE_MNEMONIC=

# Optional: destination/message/template hex for send
DESTINATION_HEX=
MESSAGE_HEX=
TEMPLATE_HEX=
